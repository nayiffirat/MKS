rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. GLOBAL SAFETY NET
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // HELPERS (Phase 3)
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Admin lookup - keep it simple first, check hardcoded root admin too
    function isAdmin(orgId) {
      return isSignedIn() && (
        (request.auth.token.email == "nayiffirat@gmail.com" && request.auth.token.email_verified == true) ||
        exists(/databases/$(database)/documents/MKS/$(orgId)/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/MKS/$(orgId)/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- Validation Blueprints (Pillar 2) ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'role', 'subscriptionStatus']) &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.role in ['user', 'admin'] &&
             data.subscriptionStatus in ['active', 'trial', 'expired'];
    }

    function isValidFarmer(data) {
      return data.fullName is string && data.fullName.size() <= 100 &&
             data.phoneNumber is string && data.phoneNumber.size() <= 20;
    }

    function isValidPrescription(data) {
      return data.farmerId is string && data.farmerId.size() <= 128 &&
             data.items is list && data.items.size() <= 50;
    }

    // ===============================================================
    // CORE RULES (Phase 4)
    // ===============================================================

    // Path: /MKS/{orgId}/users/{userId}
    match /MKS/{orgId}/users/{userId} {
      allow read: if isOwner(userId) || isAdmin(orgId);
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().role == 'user'; // Users can't create themselves as admin
      
      allow update: if (isOwner(userId) && 
                        incoming().role == existing().role && // Can't change own role
                        incoming().subscriptionStatus == existing().subscriptionStatus // Can't change own sub status
                       ) || isAdmin(orgId);

      // Sub-collections (Farmers, Prescriptions, etc.)
      match /{collectionName}/{docId} {
        // Enforce secure list queries (Pillar 8)
        allow list: if isOwner(userId) || isAdmin(orgId);
        
        allow get: if isOwner(userId) || isAdmin(orgId);
        
        allow create: if (isOwner(userId) || isAdmin(orgId)) && 
                        isValidId(docId) &&
                        (collectionName != 'farmers' || isValidFarmer(incoming())) &&
                        (collectionName != 'prescriptions' || isValidPrescription(incoming()));
                        
        allow update: if (isOwner(userId) || isAdmin(orgId)) && 
                        (collectionName != 'farmers' || isValidFarmer(incoming())) &&
                        (collectionName != 'prescriptions' || isValidPrescription(incoming()));
                        
        allow delete: if isOwner(userId) || isAdmin(orgId);
      }
    }

    // Global Collections
    match /MKS/{orgId}/news/{newsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin(orgId);
    }
    
    match /pesticides/{pesticideId} {
      allow read: if isSignedIn();
      allow write: if isAdmin("g892bEaJyGfEq1Fa67yb"); // Fixed org for global pesticides
    }
  }
}
