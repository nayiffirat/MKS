rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Path: /MKS/{orgId}/users/{userId}/{collection}/{docId}
    //
    // Collections:
    //   - farmers: Farmer profiles
    //   - prescriptions: Prescriptions issued
    //   - inventory: Stock items
    //   - payments: Farmer payments
    //   - manualDebts: Farmer debts
    //   - suppliers: Supplier profiles
    //   - supplierPurchases: Purchases from suppliers
    //   - supplierPayments: Payments to suppliers
    //   - myPayments: Checks/Promissory notes tracking
    //   - expenses: Business expenses
    //   - accounts: Cash/Bank accounts
    //   - transactions: Financial transactions
    //   - teamMembers: Team members (sub-users)
    //   - messages: Chat messages
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin(orgId) {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/MKS/$(orgId)/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "nayiffirat@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidDate(dateStr) {
      return dateStr is string && dateStr.matches("^\\d{4}-\\d{2}-\\d{2}.*");
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /MKS/{orgId}/users/{userId} {
      // User profile access
      allow read: if isOwner(userId) || isAdmin(orgId);
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin(orgId);

      // Sub-collections
      match /{collectionName}/{docId} {
        allow read: if isOwner(userId) || isAdmin(orgId);
        allow create, update: if (isOwner(userId) || isAdmin(orgId)) && request.resource.data.id == docId;
        allow delete: if isOwner(userId) || isAdmin(orgId);
      }
    }

    match /MKS/{orgId}/news/{newsId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(orgId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
