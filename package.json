    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@google/genai": "latest",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "firebase": "^10.12.0",
    "html2canvas": "^1.4.1",
